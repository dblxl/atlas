---
import "../styles/global.css";

export interface Props {
  title?: string;
}

const { title = "Atlas" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <main class="mx-auto min-h-screen w-full max-w-6xl px-6 py-12 md:px-10 md:py-16">
      <slot />
    </main>
  </body>
</html>
