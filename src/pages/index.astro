---
import BaseLayout from "../layout/BaseLayout.astro";
---

<BaseLayout title="Atlas | DoubleXL">
  <section class="relative overflow-hidden rounded-[28px] border border-border bg-panel px-6 py-8 shadow-panel backdrop-blur md:px-10 md:py-12">
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent to-transparent opacity-70"></div>
    <div class="grid gap-10 lg:grid-cols-[1.4fr_0.9fr]">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.28em] text-muted">DoubleXL Reference System</p>
        <h1 class="mt-4 max-w-3xl text-4xl font-semibold tracking-tight text-text md:text-6xl">
          Observable RAG Reference Architecture
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-muted md:text-lg">
          A practical reference for retrieval systems that must be measurable, maintainable, and cost-aware.
        </p>
      </div>
      <div class="rounded-2xl border border-border bg-[var(--color-panel-strong)]/80 p-6">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-muted">Current Scope</p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-muted">
          <li>Source Ingestion Interfaces</li>
          <li>Chunking & Embedding Logic</li>
          <li>Storage & Retrieval Scoring</li>
          <li>Response Evaluation</li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
