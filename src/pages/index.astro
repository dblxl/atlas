---
import BaseLayout from "../layout/BaseLayout.astro";

const references = [
  "docs/chunking-strategies.md",
  "docs/embedding-comparison.md",
  "docs/retrieval-flow.md",
  "ARCHITECTURE.md",
  "ROADMAP.md",
  "src/contracts/source.ts",
  "src/contracts/chunk.ts",
  "src/contracts/retrieval.ts",
  "src/contracts/observability.ts",
];
---

<BaseLayout title="Atlas | DoubleXL">
  <section class="relative overflow-hidden rounded-[28px] border border-border bg-panel px-6 py-8 shadow-panel backdrop-blur md:px-10 md:py-12">
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent to-transparent opacity-70"></div>
    <div class="grid gap-10 lg:grid-cols-[1.35fr_0.95fr]">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.28em] text-muted">DoubleXL Reference System</p>
        <h1 class="mt-4 max-w-3xl text-4xl font-semibold tracking-tight text-text md:text-6xl">
          Retrieval architecture that stays inspectable when systems leave the demo stage.
        </h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-muted md:text-lg">
          Atlas frames ingestion, chunking, embedding, indexing, scoring, and evaluation as separate layers so teams can improve retrieval quality with evidence instead of guesswork.
        </p>
      </div>
      <div class="rounded-2xl border border-border bg-[var(--color-panel-strong)]/80 p-6">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-muted">Current Scope</p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-muted">
          <li>Documentation-first retrieval architecture</li>
          <li>Observable scoring and evaluation references</li>
          <li>Provider-agnostic system boundaries</li>
          <li>Static site shell for independent publishing</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
    {references.map((reference) => (
      <article class="rounded-2xl border border-border bg-panel p-5 backdrop-blur">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-muted">Reference</p>
        <h2 class="mt-3 break-all text-sm font-medium text-text">{reference}</h2>
      </article>
    ))}
  </section>
</BaseLayout>
